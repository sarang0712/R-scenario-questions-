🧠 Scenario 2 Dataset — employees
library(tidyverse)

set.seed(123)

employees <- tibble(
  id = 1:85,
  name = paste0("Emp", 1:85),
  department = sample(c("HR", "IT", "Finance", "Sales"), 85, replace = TRUE),
  salary = sample(2000:10000, 85, replace = TRUE),
  age = sample(21:60, 85, replace = TRUE),
  experience = sample(0:35, 85, replace = TRUE),
  city = sample(c("Singapore", "KL", "Bangkok", "Jakarta"), 85, replace = TRUE),
  performance_score = sample(1:100, 85, replace = TRUE),
  bonus_eligible = sample(c("Yes", "No"), 85, replace = TRUE),
  hire_year = sample(2000:2024, 85, replace = TRUE)
)

