-----------------------------
1. CUSTOMERS TABLE (R code)
-----------------------------
library(tibble)

customers <- tribble(
  ~customer_id, ~name,     ~city,
  1,           "Asha",    "Bangalore",
  2,           "Ravi",    "Mysore",
  3,           "Neha",    "Mumbai",
  4,           "Kiran",   "Pune"
)

-----------------------------
2. PRODUCTS TABLE (R code)
-----------------------------
products <- tribble(
  ~product_id, ~product_name, ~category,   ~price,
  101,        "Laptop",      "Electronics", 60000,
  102,        "Phone",       "Electronics", 20000,
  103,        "Shoes",       "Fashion",     3000,
  104,        "Watch",       "Fashion",     5000
)

-----------------------------
3. ORDERS TABLE (R code)
-----------------------------
orders <- tribble(
  ~order_id, ~customer_id, ~order_date,   ~total_amount,
  1001,      1,            "2026-01-10",  65000,
  1002,      2,            "2026-01-11",  20000,
  1003,      3,            "2026-01-12",  8000,
  1004,      5,            "2026-01-13",  3000   # invalid customer_id
)

-----------------------------
4. ORDER ITEMS TABLE (R code)
-----------------------------
order_items <- tribble(
  ~order_id, ~product_id, ~quantity,
  1001,      101,        1,
  1001,      104,        1,
  1002,      102,        1,
  1003,      103,        2,
  1005,      103,        1   # missing order scenario
)

-----------------------------
5. MASTER DATASET (JOIN LOGIC)
-----------------------------
master_data <- orders |>
  left_join(customers, by = "customer_id") |>
  left_join(order_items, by = "order_id") |>
  left_join(products, by = "product_id")

